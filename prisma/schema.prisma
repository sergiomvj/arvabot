generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model organizations {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String   @unique
  name          String
  plan          String   @default("starter")
  logo_url      String?
  primary_color String   @default("#10B981")
  openclaw_api_key String?
  openclaw_url  String   @default("https://dashboard.fbrapps.com")
  active        Boolean  @default(true)
  created_at    DateTime @default(now())

  organization_members organization_members[]
  profiles           profiles[]
  agents_cache       agents_cache[]
  agent_status       agent_status[]
  invitations        invitations[]
  agent_threads      agent_threads[]
  squads             squads[]
  skill_bindings     organization_skill_bindings[]
  squad_templates    squad_templates[]
  squad_runs         squad_runs[]
  squad_checkpoints  squad_checkpoints[]
  architect_suggestions architect_suggestions[]
  browser_sessions   browser_sessions[]
  projects           project[]

  @@map("organizations")
}

model organization_members {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String   @db.Uuid
  role            String   @default("member")
  joined_at       DateTime @default(now())

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id])
  @@index([user_id])
  @@map("organization_members")
}

model profiles {
  id             String     @id @db.Uuid
  full_name      String?
  avatar_url     String?
  current_org_id String?    @db.Uuid
  created_at     DateTime   @default(now())

  organization organizations? @relation(fields: [current_org_id], references: [id])

  @@index([current_org_id])
  @@map("profiles")
}

model agents_cache {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  openclaw_id     String
  name            String
  role            String?
  career          String?
  model           String?
  color           String   @default("#10B981")
  active          Boolean  @default(true)
  skills          String[]
  last_synced_at  DateTime?
  metadata        Json?
  
  // Novos campos para integração com rankings/tasks
  owningTeamId      String?  @db.Uuid
  primaryFunctionId String?  @db.Uuid

  status          agent_status? @relation("AgentToStatus", fields: [organization_id, openclaw_id], references: [organization_id, openclaw_id])
  threads         agent_threads[]
  squad_steps     squad_steps[]
  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  
  scorecards      period_scorecard[]
  badge_awards    badge_award[]
  consequences    consequence_event[]
  task_executions task_execution[]

  @@unique([organization_id, openclaw_id])
  @@index([organization_id, active])
  @@index([organization_id, last_synced_at])
  @@map("agents_cache")
}

model agent_status {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  openclaw_id     String
  status          String   @default("offline")
  last_seen       DateTime?
  tasks_pending   Int      @default(0)
  tasks_done      Int      @default(0)
  updated_at      DateTime @default(now())

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  agent        agents_cache? @relation("AgentToStatus")

  @@unique([organization_id, openclaw_id])
  @@index([organization_id, status])
  @@index([organization_id, updated_at])
  @@map("agent_status")
}

model invitations {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  email           String
  role            String   @default("member")
  token           String   @unique
  expires_at      DateTime @default(now())
  created_by      String?  @db.Uuid
  accepted_at     DateTime?
  created_at      DateTime @default(now())

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, email])
  @@index([expires_at])
  @@map("invitations")
}

model agent_threads {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  agent_id        String
  user_identifier String
  theme           String
  context         String   @db.Text
  channel         String?
  status          String   @default("active") // active | resolved
  last_interaction DateTime @default(now())
  created_at      DateTime @default(now())

  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  agent        agents_cache @relation(fields: [organization_id, agent_id], references: [organization_id, openclaw_id], onDelete: Cascade)

  @@index([organization_id, agent_id, user_identifier, status, last_interaction])
  @@index([organization_id, agent_id, status, last_interaction])
  @@index([organization_id, status, last_interaction])
  @@map("agent_threads")
}

model squads {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  slug            String?
  name            String
  description     String?
  architect_prompt String?  @db.Text
  autonomy_mode   String   @default("interactive")
  status          String   @default("draft")
  architect_summary String? @db.Text
  preset_key      String?
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  steps          squad_steps[]
  runs           squad_runs[]

  @@unique([organization_id, slug])
  @@index([organization_id, active, status])
  @@map("squads")
}

model squad_steps {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squad_id        String   @db.Uuid
  organization_id String   @db.Uuid
  agent_id        String
  order           Int
  instructions    String   @db.Text
  title           String?
  step_type       String   @default("agent_task")
  skill_code      String?
  checkpoint_required Boolean @default(false)

  squad           squads       @relation(fields: [squad_id], references: [id], onDelete: Cascade)
  agent           agents_cache @relation(fields: [organization_id, agent_id], references: [organization_id, openclaw_id], onDelete: Cascade)
  run_steps       squad_run_steps[]

  @@unique([squad_id, order])
  @@index([organization_id, skill_code])
  @@map("squad_steps")
}

model squad_runs {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squad_id        String   @db.Uuid
  organization_id String   @db.Uuid
  status          String   @default("queued")
  current_step    Int?
  started_by      String?  @db.Uuid
  input_payload   Json?
  output_summary  Json?
  started_at      DateTime @default(now())
  completed_at    DateTime?
  failed_at       DateTime?
  updated_at      DateTime @updatedAt

  squad           squads         @relation(fields: [squad_id], references: [id], onDelete: Cascade)
  organization    organizations  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  steps           squad_run_steps[]
  checkpoints     squad_checkpoints[]

  @@index([organization_id, status, updated_at])
  @@index([squad_id, started_at])
  @@map("squad_runs")
}

model squad_run_steps {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_id          String   @db.Uuid
  squad_step_id   String   @db.Uuid
  status          String   @default("pending")
  output_text     String?  @db.Text
  output_payload  Json?
  handoff_summary String?  @db.Text
  started_at      DateTime?
  completed_at    DateTime?
  error_message   String?  @db.Text
  created_at      DateTime @default(now())

  run             squad_runs  @relation(fields: [run_id], references: [id], onDelete: Cascade)
  squad_step      squad_steps @relation(fields: [squad_step_id], references: [id], onDelete: Cascade)
  checkpoints     squad_checkpoints[]

  @@index([run_id, status, created_at])
  @@index([squad_step_id])
  @@map("squad_run_steps")
}

model squad_checkpoints {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  run_id          String   @db.Uuid
  run_step_id     String   @db.Uuid
  status          String   @default("open")
  action          String?
  feedback_text   String?  @db.Text
  selection_payload Json?
  resolved_by     String?  @db.Uuid
  created_at      DateTime @default(now())
  resolved_at     DateTime?

  organization    organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  run             squad_runs      @relation(fields: [run_id], references: [id], onDelete: Cascade)
  run_step        squad_run_steps @relation(fields: [run_step_id], references: [id], onDelete: Cascade)

  @@index([organization_id, status, created_at])
  @@index([run_id, status])
  @@map("squad_checkpoints")
}

model skill_definitions {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  name            String
  description     String?  @db.Text
  type            String
  provider        String?
  plan_gate       String?
  status          String   @default("active")
  config_schema   Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization_bindings organization_skill_bindings[]

  @@index([status, type])
  @@map("skill_definitions")
}

model organization_skill_bindings {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  skill_id        String   @db.Uuid
  status          String   @default("enabled")
  config          Json?
  secret_ref      String?
  enabled_by      String?  @db.Uuid
  enabled_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization    organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  skill           skill_definitions @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, skill_id])
  @@index([organization_id, status])
  @@map("organization_skill_bindings")
}

model squad_templates {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?  @db.Uuid
  key             String   @unique
  name            String
  description     String?  @db.Text
  category        String?
  active          Boolean  @default(true)
  autonomy_mode   String   @default("interactive")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization    organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  steps           squad_template_steps[]

  @@index([organization_id, active])
  @@map("squad_templates")
}

model squad_template_steps {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  template_id     String   @db.Uuid
  organization_id String?  @db.Uuid
  agent_id        String
  order           Int
  title           String?
  instructions    String   @db.Text
  checkpoint_required Boolean @default(false)
  step_type       String   @default("agent_task")
  skill_code      String?

  template        squad_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@unique([template_id, order])
  @@map("squad_template_steps")
}

model architect_suggestions {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  created_by      String?  @db.Uuid
  prompt          String   @db.Text
  suggestion      Json
  created_at      DateTime @default(now())

  organization    organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, created_at])
  @@map("architect_suggestions")
}

model project {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  code            String   @unique
  name            String
  description     String?  @db.Text
  documentation   String?  @db.Text
  status          String   @default("active")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization    organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  tasks           project_task[]

  @@index([organization_id, status])
  @@map("projects")
}

model project_task {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id      String   @db.Uuid
  title           String
  description     String?  @db.Text
  status          String   @default("backlog")
  criticality     String   @default("medium")
  complexity      String   @default("standard")
  assigned_agent_id String? @db.Uuid
  sequence        Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  project         project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id, status])
  @@map("project_tasks")
}

model evaluation_period {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  periodType      String
  startsAt        DateTime
  endsAt          DateTime
  isClosed        Boolean  @default(false)
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scorecards      period_scorecard[]

  @@map("evaluation_periods")
}

model period_scorecard {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodId        String   @db.Uuid
  agentId         String   @db.Uuid
  scoreValue      Decimal  @db.Decimal(10, 2)
  scoreStatus     String
  sampleSize      Int
  confidenceIndex Decimal  @db.Decimal(5, 2)
  rankPosition    Int?
  trendDelta      Decimal? @db.Decimal(5, 2)
  operationalBand String
  explanation     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  period          evaluation_period @relation(fields: [periodId], references: [id], onDelete: Cascade)
  agent           agents_cache      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([periodId, agentId])
  @@map("period_scorecards")
}

model badge {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  name            String
  description     String   @db.Text
  badgeCategory   String
  createdAt       DateTime @default(now())

  awards          badge_award[]

  @@map("badges")
}

model badge_award {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  badgeId         String   @db.Uuid
  agentId         String   @db.Uuid
  awardedAt       DateTime @default(now())

  badge           badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  agent           agents_cache @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("badge_awards")
}

model ranking_rule {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  name            String
  actionType      String
  createdAt       DateTime @default(now())

  consequences    consequence_event[]

  @@map("ranking_rules")
}

model consequence_event {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId         String   @db.Uuid
  ruleId          String   @db.Uuid
  status          String
  triggeredAt     DateTime @default(now())

  agent           agents_cache @relation(fields: [agentId], references: [id], onDelete: Cascade)
  rule            ranking_rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("consequence_events")
}

model task_execution {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId         String   @db.Uuid
  taskTypeId      String   @db.Uuid
  startedAt       DateTime
  completedAt     DateTime?
  executionStatus String
  scoreRaw        Decimal? @db.Decimal(10, 2)
  scoreFinal      Decimal? @db.Decimal(10, 2)

  agent           agents_cache @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task_type       task_type    @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)

  @@index([agentId, startedAt])
  @@map("task_executions")
}

model task_type {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  name            String
  createdAt       DateTime @default(now())

  executions      task_execution[]

  @@map("task_types")
}

model function_catalog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?  @db.Text
  createdAt       DateTime @default(now())

  @@map("function_catalog")
}

model browser_sessions {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String   @db.Uuid
  platform        String
  cookies         Json?
  storage_state   Json?
  updated_at      DateTime @default(now())

  organization    organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, platform])
  @@map("browser_sessions")
}
